# Phil G. — environment variables
#
# Copy this file to `.env.local` (gitignored) and fill in the values
# you want to use locally. Production reads from Vercel → Settings →
# Environment Variables.

# --- Admin password (REQUIRED) ---------------------------------------
#
# Password for the /admin section. Required for the admin to load —
# without it the login route returns 503.
#
# Set this in:
#   - .env.local for local dev
#   - Vercel → Settings → Environment Variables (Production scope)
ADMIN_PASSWORD=change-me

# --- Vercel Blob (auto-injected by Vercel) ---------------------------
#
# This is set automatically by Vercel when you create a Blob store
# from the dashboard (Storage → Create → Blob). The admin uses it to
# write edited MDX content + uploaded audio files at runtime.
#
# DO NOT set this manually. Just create the store in Vercel.
# Local dev works without it — saves write to the filesystem instead.
# BLOB_READ_WRITE_TOKEN=

# --- Optional: site URL override -------------------------------------
#
# Used by sitemap/robots/JSON-LD when running outside Vercel.
# NEXT_PUBLIC_SITE_URL=https://philg.cz
