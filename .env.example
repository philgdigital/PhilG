# Phil G. — environment variables
#
# Copy this file to `.env.local` (which IS gitignored) and fill in
# the values you actually want to use. The runtime reads `.env.local`
# in dev and the matching Vercel environment in production.

# --- Admin auth -------------------------------------------------------
#
# Password for the /admin section (login at /admin/login). Required
# for the admin to function — without it the login route returns 503
# so the admin can never be reached without explicit configuration.
#
# Set this LOCALLY (.env.local) for dev AND in Vercel → Settings →
# Environment Variables (Production) for the live admin.
#
# Pick a long random string. There's no recovery flow.
ADMIN_PASSWORD=change-me

# --- Admin: production storage (Vercel only) --------------------------
#
# When these are set, the admin commits MDX changes through the GitHub
# API and uploads audio to Vercel Blob instead of writing the local
# filesystem (which is read-only at runtime on Vercel).
#
# Leave UNSET in local dev — the admin will use the filesystem and
# regenerate data.json in-process for instant feedback.

# Fine-grained personal access token with "Contents: Read and write"
# on the philgdigital/PhilG repo. Generate at:
#   https://github.com/settings/personal-access-tokens
# Add as a Vercel env var named GITHUB_TOKEN.
# GITHUB_TOKEN=

# Repo to commit into, in "owner/name" form.
# GITHUB_REPO=philgdigital/PhilG

# Branch to commit to. Defaults to "main" if unset.
# GITHUB_BRANCH=main

# Vercel Blob read/write token. Provisioned automatically when you
# create a Blob store from the Vercel dashboard — Vercel injects this
# into your env at deploy time. Locally you can copy it from the
# dashboard if you want to test the blob path.
# BLOB_READ_WRITE_TOKEN=

# --- Optional public site URL override --------------------------------
#
# Used by sitemap/robots/JSON-LD to emit absolute URLs in non-Vercel
# environments. Leave unset for normal Vercel deploys.
# NEXT_PUBLIC_SITE_URL=https://philg.cz
