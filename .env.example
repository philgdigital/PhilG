# Phil G. — environment variables
#
# Copy this file to `.env.local` (which IS gitignored) and fill in
# the values you actually want to use. The runtime reads `.env.local`
# in dev and the matching Vercel environment in production.

# --- Local admin (npm run dev only) ----------------------------------
#
# Password for the /admin section (login at /admin/login). This is
# required for the admin to function — without it the login route
# returns 503 so the admin can never be reached without explicit
# configuration.
#
# The admin only runs in development (proxy.ts hard-blocks it in
# production with a 404), so this never needs to be set on Vercel.
#
# Pick something memorable. There's no recovery flow.
ADMIN_PASSWORD=change-me

# --- Optional public site URL override --------------------------------
#
# Used by sitemap/robots/JSON-LD to emit absolute URLs in non-Vercel
# environments. Leave unset for normal Vercel deploys.
# NEXT_PUBLIC_SITE_URL=https://philg.cz
